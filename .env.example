# ========================================================================
# RedEye Policy Engine - Environment Configuration
# ========================================================================
# PROFESSIONAL SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Generate secure values using: openssl rand -base64 32
# 3. NEVER commit .env to version control
# 4. Use AWS Secrets Manager / HashiCorp Vault in production

# ── POSTGRES CREDENTIALS ───────────────────────────────────────────────
POSTGRES_USER=RedEye
# REQUIRED: Generate strong password
POSTGRES_PASSWORD=generate_strong_password_here
POSTGRES_DB=RedEye

# ── REDIS CREDENTIALS ──────────────────────────────────────────────────
# REQUIRED: Generate strong password
REDIS_PASSWORD=generate_strong_password_here

# ── CLICKHOUSE CREDENTIALS ─────────────────────────────────────────────
CLICKHOUSE_USER=RedEye
# REQUIRED: Generate strong password
CLICKHOUSE_PASSWORD=generate_strong_password_here
CLICKHOUSE_DB=RedEye_telemetry

# ── SECURITY KEYS (MUST BE EXACTLY 32 BYTES) ────────────────────────────
# Generate with: openssl rand -base64 32
# REQUIRED for production
JWT_SECRET=place_32_byte_base64_encoded_jwt_secret_here_____________
AES_MASTER_KEY=place_32_byte_base64_encoded_aes_key_here_____________

# ── OPENAI CONFIGURATION ───────────────────────────────────────────────
# REQUIRED: Your actual OpenAI API key
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── ENVIRONMENT ────────────────────────────────────────────────────────
# Options: development, staging, production
ENVIRONMENT=development

# ── LOGGING ────────────────────────────────────────────────────────────
# Options: trace, debug, info, warn, error
RUST_LOG=info
LOG_JSON=false
LOG_CONSOLE=true
DEBUG=false

# ── SERVICE CONFIGURATION ──────────────────────────────────────────────
GATEWAY_PORT=8080
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

GEMINI_API_KEY=your_gemini_api_key_here

